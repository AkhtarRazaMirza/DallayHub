{
  "name": "dallyhub-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "startDB": "docker compose up -d",
    "stopDB": "docker compose down",
    "studio": "drizzle-kit studio",
    "generateDB": "drizzle-kit generate",
    "migrateDB": "drizzle-kit migrate"
  },
  "keywords": [
    "auth",
    "authentication",
    "authorization",
    "jwt",
    "bcrypt",
    "nodejs",
    "express",
    "postgresql",
    "oauth2.0"
  ],
  "author": "Akhtar Raza",
  "license": "ISC",
  "type": "module",
  "description": "This is a secure authentication system built with Node.js, Express, and PostgreSQL. It provides features such as user registration, login, password hashing, JWT-based authentication, and email verification. and it also have oauth2.0 authentication with google and github",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "typescript": "^5.8.3"
  }
}
