{
  "name": "dallyhub-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "startDB": "docker compose up -d",
    "stopDB": "docker compose down",
    "studio": "drizzel-kit studio",
    "generateDB": "drizzle-kit generate",
    "migrateDB": "drizzle-kit migrate"
  },
  "keywords": ["auth", "authentication", "authorization", "jwt", "bcrypt", "nodejs", "express", "postgresql", "oauth2.0"],
  "author": "Akhtar Raza",
  "license": "ISC",
  "type": "module",
  "description": "This is a secure authentication system built with Node.js, Express, and PostgreSQL. It provides features such as user registration, login, password hashing, JWT-based authentication, and email verification. and it also have oauth2.0 authentication with google and github",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "tsc": "^2.0.4",
    "zod": "^4.3.6"
  }
}
